<% content_for :title, "hushpair" %>

<main class="shell" id="main-content">
  <section class="hero">
    <h1>Private one-to-one chat with one simple link.</h1>
    <p class="lede">
      No accounts, no feeds, no attachments, no audience.
    </p>
  </section>

  <section class="card-grid">
    <section class="card">
      <h2>Create a private room</h2>
      <p>Create a private room, share the invite, and enter when you're ready.</p>

      <%= form_with url: rooms_path, method: :post, class: "stack" do |form| %>
        <%= form.label :nickname, "Nickname (optional)" %>
        <%= form.text_field :nickname, maxlength: 40, placeholder: "Quiet Fox" %>
        <%= form.submit "Create private chat", class: "button" %>
      <% end %>
    </section>

    <section class="card">
      <h2>Join with a link</h2>
      <p>Open the private invite you received to enter the room.</p>
    </section>
  </section>

  <% if @open_room_participations.any? %>
    <section class="card home-room-list">
      <div class="home-room-list__header">
        <h2>Your open rooms</h2>
        <p>Rooms still available in this browser.</p>
      </div>

      <ul class="home-room-list__items">
        <% @open_room_participations.each do |participation| %>
          <% room = participation.room %>
          <li class="home-room-list__item">
            <div>
              <p class="home-room-list__name"><%= room.slug.tr("-", " ") %></p>
              <p class="home-room-list__meta">
                <span><%= participation.role == "creator" ? "Creator" : "Guest" %></span>
                <span aria-hidden="true">·</span>
                <span><%= room.retention_summary %></span>
                <span aria-hidden="true">·</span>
                <span><%= room.expiry_summary %></span>
              </p>
            </div>
            <%= link_to "Open", room_path(room), class: "button button-secondary button-compact" %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</main>

<div class="chat-transcript">
  <ol class="message-list" id="message-list" role="log" aria-live="polite" aria-relevant="additions text" aria-label="Chat messages">
    <% messages.each do |message| %>
      <li class="message-row <%= message.room_participant_id == participant.id ? "message-row-local" : "message-row-remote" %>" data-sequence-number="<%= message.sequence_number %>">
        <div class="message-shell">
          <span class="message-meta">
            <strong><%= message.room_participant.nickname.presence || "Anonymous" %></strong>
            <time datetime="<%= message.created_at.iso8601 %>"><%= message.created_at.strftime("%-I:%M %p") %></time>
          </span>
          <span class="message-body"><%= message.body %></span>
        </div>
      </li>
    <% end %>
  </ol>

  <p class="empty-state <%= "is-hidden" if messages.any? %>" id="empty-state">
    No messages yet. Say hello when you're ready.
  </p>
</div>

<div class="chat-actions">
  <details class="report-disclosure">
    <summary class="button button-secondary button-compact report-disclosure__summary">Report</summary>
    <%= form_with url: report_room_path(room), method: :post, class: "report-form", data: { chat_confirm: "Report this chat and end it for both people?" } do %>
      <%= hidden_field_tag :participant_token, participant_return_token if participant_return_token.present? %>
      <%= select_tag :reason, options_for_select([
        ["Harassment", "harassment"],
        ["Spam", "spam"],
        ["Hate or threats", "hate"],
        ["Self-harm", "self-harm"],
        ["Other", "other"]
      ]), class: "toolbar-input toolbar-input-small" %>
      <%= submit_tag "Report and End", class: "button button-secondary button-compact" %>
    <% end %>
  </details>

  <% if room.random_match? %>
    <%= form_with url: next_room_path(room), method: :post, data: { chat_confirm: "Leave this chat and look for someone new?" } do %>
      <%= hidden_field_tag :participant_token, participant_return_token if participant_return_token.present? %>
      <%= submit_tag "Next", class: "button button-secondary button-compact" %>
    <% end %>
  <% end %>

  <%= form_with url: leave_room_path(room), method: :post, data: { chat_confirm: "End this chat for both people?" } do %>
    <%= hidden_field_tag :participant_token, participant_return_token if participant_return_token.present? %>
    <%= submit_tag "End chat", class: "button button-secondary button-compact" %>
  <% end %>
</div>

<div class="chat-header">
  <div class="chat-header__main">
    <div class="chat-header__status">
      <span class="room-pill" data-chat-room-pill role="status" aria-live="polite"><%= room.status.humanize %></span>
      <span class="chat-header__identity"><%= participant.nickname.presence || "Anonymous" %></span>
    </div>
    <div class="chat-header__link-slot">
      <% if share_invite_url.present? %>
        <div
          class="chat-header__link-bar"
          data-chat-header-link
          data-copy-value="<%= share_invite_url %>"
          data-share-url="<%= share_invite_url %>"
          data-bookmark-url="<%= participant_return_url %>"
          data-waiting-label="Share link"
          data-active-label="Bookmark"
        >
          <span class="chat-header__link-label" data-chat-header-link-label>Share link</span>
          <input class="chat-header__link-input" data-chat-header-link-text type="text" readonly value="<%= share_invite_url %>" aria-label="Share link" />
          <button class="button button-secondary button-copy" type="button">Copy</button>
        </div>
      <% elsif participant_return_url.present? %>
        <div
          class="chat-header__link-bar"
          data-chat-header-link
          data-copy-value="<%= participant_return_url %>"
          data-bookmark-url="<%= participant_return_url %>"
          data-active-label="Bookmark"
        >
          <span class="chat-header__link-label" data-chat-header-link-label>Bookmark</span>
          <input class="chat-header__link-input" data-chat-header-link-text type="text" readonly value="<%= participant_return_url %>" aria-label="Bookmark link" />
          <button class="button button-secondary button-copy" type="button">Copy</button>
        </div>
      <% end %>
    </div>
  </div>
  <details class="chat-menu" data-chat-menu>
    <summary class="chat-menu__trigger" data-chat-menu-trigger aria-label="Open chat settings">
      <span></span>
      <span></span>
      <span></span>
    </summary>
    <div class="chat-menu__panel">
      <div class="toolbar-pair-grid">
      <div class="toolbar-group toolbar-group-retention">
        <span class="toolbar-label-group">
          <span class="toolbar-label">Message Retention</span>
          <span class="help-badge" tabindex="0">
            ?
            <span class="help-popover">
              Controls how much chat history hushpair keeps for this room.
                <% if room.random_match? %>
                  This setting is chosen by hushpair for matched chats.
                <% elsif !participant.creator? %>
                  This setting was chosen by the room creator.
                <% end %>
              </span>
            </span>
          </span>

          <% if participant.creator? && room.invite_only? %>
            <%= form_with url: retention_room_path(room), method: :patch, class: "toolbar-retention-form" do |form| %>
              <%= form.select :message_retention_mode, options_for_select(retention_options, room.message_retention_mode), {}, class: "select-input toolbar-input", data: { chat_retention_mode_select: true } %>
              <div class="retention-inline-group retention-detail-group" data-retention-detail="line_count" <%= "hidden" unless room.line_count? %>>
                <%= form.number_field :message_retention_line_limit, min: 10, max: 10000, step: 10, class: "toolbar-input toolbar-input-small", placeholder: "250" %>
                <span class="toolbar-unit">messages</span>
              </div>
              <div class="retention-inline-group retention-detail-group" data-retention-detail="time_window" <%= "hidden" unless room.time_window? %>>
                <%= form.number_field :message_retention_hours, min: 1, max: 720, step: 1, class: "toolbar-input toolbar-input-small", placeholder: "24" %>
                <span class="toolbar-unit">hours</span>
              </div>
              <span class="toolbar-unit retention-detail-group" data-retention-detail="forever" <%= "hidden" unless room.forever? %>>room expiry</span>
              <% if params[:participant_token].present? %>
                <%= hidden_field_tag :participant_token, params[:participant_token] %>
              <% end %>
              <%= form.submit "Save", class: "button button-secondary button-compact" %>
            <% end %>
          <% else %>
            <span class="settings-pill"><%= room.random_match? ? room.retention_short_summary : room.retention_summary %></span>
          <% end %>
        </div>
      </div>

      <div class="toolbar-group">
        <span class="toolbar-label-group">
          <span class="toolbar-label">Lifetime</span>
          <span class="help-badge" tabindex="0">
            ?
            <span class="help-popover">Waiting rooms expire after 30 minutes. Once both people join, active rooms last 24 hours and extend when new messages are sent, up to 30 days from creation.</span>
          </span>
        </span>
        <span class="settings-pill" data-chat-room-expiry-summary><%= room_expiry_summary %></span>
      </div>

      <div class="toolbar-group toolbar-group-actions">
        <span class="toolbar-label">Room</span>
        <div class="menu-actions">
          <details class="report-disclosure">
            <summary class="button button-secondary button-compact report-disclosure__summary">Report</summary>
            <%= form_with url: report_room_path(room), method: :post, class: "report-form", data: { chat_confirm: "Report this chat and end it for both people?" } do %>
              <%= hidden_field_tag :participant_token, participant_return_token if participant_return_token.present? %>
              <%= select_tag :reason, options_for_select([
                ["Harassment", "harassment"],
                ["Spam", "spam"],
                ["Hate or threats", "hate"],
                ["Self-harm", "self-harm"],
                ["Other", "other"]
              ]), class: "toolbar-input toolbar-input-small" %>
              <%= submit_tag "Report and End", class: "button button-secondary button-compact" %>
            <% end %>
          </details>
          <% if room.random_match? %>
            <%= form_with url: next_room_path(room), method: :post, data: { chat_confirm: "Leave this chat and look for someone new?" } do %>
              <%= hidden_field_tag :participant_token, participant_return_token if participant_return_token.present? %>
              <%= submit_tag "Next", class: "button button-secondary button-compact" %>
            <% end %>
          <% end %>
          <%= form_with url: leave_room_path(room), method: :post, data: { chat_confirm: "End this chat for both people?" } do %>
            <%= hidden_field_tag :participant_token, participant_return_token if participant_return_token.present? %>
            <%= submit_tag "End chat", class: "button button-secondary button-compact" %>
          <% end %>
        </div>
      </div>
    </div>
  </details>
</div>

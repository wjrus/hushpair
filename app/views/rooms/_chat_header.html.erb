<div class="chat-header">
  <div class="chat-header__main">
    <div class="chat-header__status">
      <span class="room-pill" data-chat-room-pill role="status" aria-live="polite"><%= room.status.humanize %></span>
      <span class="chat-header__identity"><%= participant.nickname.presence || "Anonymous" %></span>
    </div>
    <div class="chat-header__link-slot">
      <% if share_invite_url.present? %>
        <div
          class="chat-header__link-bar"
          data-chat-header-link
          data-copy-value="<%= share_invite_url %>"
          data-share-url="<%= share_invite_url %>"
          data-bookmark-url="<%= participant_return_url %>"
          data-waiting-label="Share link"
          data-active-label="Bookmark"
        >
          <span class="chat-header__link-label" data-chat-header-link-label>Share link</span>
          <input class="chat-header__link-input" data-chat-header-link-text type="text" readonly value="<%= share_invite_url %>" aria-label="Share link" />
          <button class="button button-secondary button-copy" type="button">Copy</button>
        </div>
      <% elsif participant_return_url.present? %>
        <div
          class="chat-header__link-bar"
          data-chat-header-link
          data-copy-value="<%= participant_return_url %>"
          data-bookmark-url="<%= participant_return_url %>"
          data-active-label="Bookmark"
        >
          <span class="chat-header__link-label" data-chat-header-link-label>Bookmark</span>
          <input class="chat-header__link-input" data-chat-header-link-text type="text" readonly value="<%= participant_return_url %>" aria-label="Bookmark link" />
          <button class="button button-secondary button-copy" type="button">Copy</button>
        </div>
      <% end %>
    </div>
  </div>
  <% if room.random_match? %>
    <%= render "chat_actions", room: room, participant_return_token: participant_return_token %>
  <% else %>
    <details class="chat-menu" data-chat-menu>
      <summary class="chat-menu__trigger" data-chat-menu-trigger aria-label="Open chat settings">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="chat-menu__panel">
        <%= render "chat_details",
          room: room,
          participant: participant,
          room_expiry_summary: room_expiry_summary,
          retention_options: retention_options %>

        <div class="toolbar-group toolbar-group-actions">
          <span class="toolbar-label">Room</span>
          <%= render "chat_actions", room: room, participant_return_token: participant_return_token %>
        </div>
      </div>
    </details>
  <% end %>
</div>

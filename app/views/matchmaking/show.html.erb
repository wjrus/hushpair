<% content_for :title, "Match now | hushpair" %>

<main class="shell match-shell" id="main-content">
  <section
    class="card match-card"
    data-match-waiting
    data-match-poll-url="<%= match_path(format: :json) %>"
  >
    <p class="eyebrow">Match now</p>
    <h1>Looking for someone now.</h1>
    <p class="lede">
      hushpair will drop you into a private one-to-one room as soon as another person is ready.
    </p>
    <% if @match_reason == "next" %>
      <p class="form-note match-note">That chat ended, so you are back in line for a new match.</p>
    <% elsif @match_reason == "renewed" %>
      <p class="form-note match-note">Still looking. We kept your place open and refreshed the search.</p>
    <% end %>

    <p class="form-note match-note match-note-strong">
      hushpair is new and not widely used yet, so matching may take a while. You can leave this tab open;
      we’ll beep if someone arrives while it’s in the background.
    </p>

    <div class="match-status">
      <span class="match-status__dot" aria-hidden="true"></span>
      <p class="match-status__text" data-match-status-text>Still looking for someone available.</p>
    </div>

    <div class="invite-preview-grid match-meta-grid">
      <div class="invite-preview-item">
        <span class="toolbar-label">Message Retention</span>
        <span class="settings-pill"><%= Room.default_retention_short_summary %></span>
      </div>
    </div>

    <p class="form-note">You can cancel any time. If nobody arrives quickly, hushpair quietly keeps looking.</p>

    <%= form_with url: match_path, method: :delete do %>
      <%= submit_tag "Cancel search", class: "button button-secondary" %>
    <% end %>
  </section>
</main>
